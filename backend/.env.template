# Copy this file to .env and fill in real values
# Never commit .env to source control

APP_ENV=dev

# Data Source Mode: LIVE | CACHED | STALE | MOCK
# LIVE   — call external MTA API, fallback to cache then mock on failure
# CACHED — serve from fresh cache only, never call external API
# STALE  — serve stale cache only (for testing degradation)
# MOCK   — always return mock data, skip API and cache entirely
DATA_SOURCE_MODE=LIVE

# Transit API Keys
# Get your MTA API key from: https://api.mta.info/#/signup
MTA_API_KEY=your-mta-api-key-here
TRANSIT_LAND_API_KEY=your-transit-land-api-key-here

# API Base URLs (override for staging/prod)
MTA_BASE_URL=https://api-endpoint.mta.info
TRANSIT_LAND_BASE_URL=https://transit.land/api/v2/rest

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Monitoring
GRAFANA_PASSWORD=changeme
