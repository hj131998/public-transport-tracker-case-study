				{
					"name": "Get Vehicle Positions",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is an array', function () {",
									"    pm.expect(pm.response.json()).to.be.an('array');",
									"});",
									"",
									"pm.test('Each vehicle has required fields', function () {",
									"    var vehicles = pm.response.json();",
									"    if (vehicles.length > 0) {",
									"        var v = vehicles[0];",
									"        pm.expect(v).to.have.property('vehicleId');",
									"        pm.expect(v).to.have.property('lat');",
									"        pm.expect(v).to.have.property('lon');",
									"        pm.expect(v).to.have.property('nextStop');",
									"        pm.expect(v).to.have.property('eta');",
									"        pm.expect(v).to.have.property('crowding');",
									"        pm.expect(v).to.have.property('delayMinutes');",
									"        pm.expect(v).to.have.property('disrupted');",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" }
						],
						"url": {
							"raw": "{{base_url}}/api/v1/transit/{{route}}/vehicles?city={{city}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "transit", "{{route}}", "vehicles"],
							"query": [
								{ "key": "city", "value": "{{city}}" }
							]
						},
						"description": "Lightweight endpoint — returns only vehicle positions for a specific route."
					}
				},
