{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
		"name": "Transport Tracker BFF API",
		"description": "Public Transport Tracker — BFF Gateway Service API Collection.\n\nCovers all REST endpoints for transit data, alerts, route planning, health checks, and actuator.\n\n**Setup:**\n1. Start the backend: `mvn spring-boot:run` (port 8080)\n2. Set the `base_url` variable if not using localhost\n3. Set `city` and `route` variables for your test scenario\n\n**MTA Subway Routes (NYC):**\n- Lines 1,2,3,4,5,6,7,S → Feed 1\n- Lines A,C,E → Feed 16\n- Lines B,D,F,M → Feed 21\n- Lines N,Q,R,W → Feed 26\n- Line L → Feed 31\n- Line G → Feed 36\n- Lines J,Z → Feed 51",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "city",
			"value": "NYC",
			"type": "string"
		},
		{
			"key": "route",
			"value": "1",
			"type": "string"
		},
		{
			"key": "from_stop",
			"value": "Times Sq",
			"type": "string"
		},
		{
			"key": "to_stop",
			"value": "Brooklyn Bridge",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Transit Data",
			"description": "Core transit data endpoints — aggregated response, vehicles, and alerts.",
			"item": [
				{
					"name": "Get Aggregated Transit Data",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has required fields', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(json).to.have.property('routeId');",
									"    pm.expect(json).to.have.property('city');",
									"    pm.expect(json).to.have.property('dataSource');",
									"    pm.expect(json).to.have.property('vehicles');",
									"    pm.expect(json).to.have.property('alerts');",
									"    pm.expect(json).to.have.property('links');",
									"});",
									"",
									"pm.test('dataSource is one of LIVE, CACHED, STALE, MOCK', function () {",
									"    var json = pm.response.json();",
									"    pm.expect(['LIVE','CACHED','STALE','MOCK']).to.include(json.dataSource);",
									"});",
									"",
									"pm.test('vehicles is an array', function () {",
									"    pm.expect(pm.response.json().vehicles).to.be.an('array');",
									"});",
									"",
									"pm.test('HATEOAS links contain self', function () {",
									"    pm.expect(pm.response.json().links).to.have.property('self');",
									"});",
									"",
									"pm.test('Response has X-Trace-Id header', function () {",
									"    pm.response.to.have.header('X-Trace-Id');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Trace-Id",
								"value": "{{$guid}}",
								"description": "Optional trace ID for distributed tracing"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/transit?city={{city}}&route={{route}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "transit"],
							"query": [
								{ "key": "city", "value": "{{city}}", "description": "City code e.g. NYC" },
								{ "key": "route", "value": "{{route}}", "description": "Route ID e.g. 1, A, F" }
							]
						},
						"description": "Primary endpoint — returns aggregated transit data including vehicles, alerts, route plan, and HATEOAS links.\n\nFallback chain: LIVE → CACHED → STALE → MOCK"
					}
				},
